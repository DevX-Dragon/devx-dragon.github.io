---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, description, tags, images, repoUrl, liveUrl, status, date } = project.data;

const TAG_COLOR = { Hardware: '#00FFE7', Software: '#FFE600', IRL: '#ffffff' };
const primaryColor = tags[0] ? TAG_COLOR[tags[0]] : '#00FFE7';
---

<Layout title={`${title} — DevX-Dragon`} description={description}>
  <main class="max-w-3xl mx-auto px-4 sm:px-8 py-12 sm:py-20">

    <!-- Back -->
    <a
      href="/#projects"
      class="inline-flex items-center gap-2 font-mono text-xs text-[#555] hover:text-[#00FFE7] uppercase tracking-widest transition-colors mb-10"
    >
      ← Back to lab
    </a>

    <!-- Tags -->
    <div class="flex gap-2 flex-wrap mb-4">
      {tags.map((tag) => (
        <span
          class="font-mono text-xs font-bold uppercase tracking-widest px-3 py-1 border-2"
          style={`border-color: ${TAG_COLOR[tag]}; color: ${TAG_COLOR[tag]};`}
        >
          {tag}
        </span>
      ))}
      <span class="font-mono text-xs font-bold uppercase tracking-widest px-3 py-1 border-2 border-[#333] text-[#555]">
        {status}
      </span>
    </div>

    <!-- Title -->
    <h1
      class="font-grotesk font-black text-white leading-none mb-6"
      style="font-size: clamp(2rem, 7vw, 4rem);"
    >
      {title}<span style={`color: ${primaryColor};`}>.</span>
    </h1>

    <!-- Hero image -->
    {images && images.length > 0 && (
      <div class="border-2 border-[#1a1a1a] overflow-hidden mb-8 relative" style={`border-color: ${primaryColor}40;`}>
        <img src={images[0]} alt={title} class="w-full object-cover max-h-96" />
        <div
          class="absolute inset-0 pointer-events-none"
          style="background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.08) 3px, rgba(0,0,0,0.08) 4px);"
        />
      </div>
    )}

    <!-- Action links -->
    <div class="flex gap-3 flex-wrap mb-10">
      {repoUrl && (
        <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="btn-lab">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.1.83-.26.83-.58v-2.02c-3.34.73-4.04-1.6-4.04-1.6-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.48 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.3.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02.004 2.04.14 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.22.7.83.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Source Code
        </a>
      )}
      {liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs uppercase tracking-widest px-4 py-2.5 border-2 border-[#FFE600] text-[#FFE600] hover:bg-[#FFE600] hover:text-[#080808] transition-all duration-150 flex items-center gap-2"
        >
          Live Demo →
        </a>
      )}
    </div>

    <!-- Markdown content -->
    <div class="prose-lab font-mono text-sm text-[#aaa] leading-relaxed">
      <Content />
    </div>

    <!-- Image gallery (extra shots) -->
    {images && images.length > 1 && (
      <div class="mt-12 pt-8 border-t-2 border-[#111]">
        <div class="font-mono text-xs text-[#444] uppercase tracking-widest mb-4">// More shots</div>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {images.slice(1).map((img, i) => (
            <div class="border border-[#1a1a1a] overflow-hidden aspect-video">
              <img src={img} alt={`${title} — photo ${i + 2}`} class="w-full h-full object-cover" />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Footer nav -->
    <div class="mt-16 pt-8 border-t border-[#111]">
      <a href="/#projects" class="btn-lab">← Back to all builds</a>
    </div>

  </main>
</Layout>

<style is:global>
  .prose-lab h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
    margin: 2rem 0 0.75rem;
  }
  .prose-lab h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #ccc;
    margin: 1.5rem 0 0.5rem;
  }
  .prose-lab p {
    margin: 0 0 1rem;
    color: #999;
  }
  .prose-lab ul, .prose-lab ol {
    padding-left: 1.25rem;
    margin: 0 0 1rem;
    color: #888;
  }
  .prose-lab li {
    margin-bottom: 0.25rem;
  }
  .prose-lab strong {
    color: #eee;
    font-weight: 700;
  }
  .prose-lab code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8em;
    background: #111;
    border: 1px solid #222;
    padding: 0.1em 0.4em;
    color: #00FFE7;
  }
  .prose-lab pre {
    background: #0a0a0a;
    border: 1px solid #1a1a1a;
    padding: 1rem;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .prose-lab pre code {
    background: none;
    border: none;
    padding: 0;
  }
  .prose-lab a {
    color: #00FFE7;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
